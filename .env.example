# App
NEXT_PUBLIC_APP_NAME=Shanghai Housing Map
NODE_ENV=development

# Map defaults
NEXT_PUBLIC_DEFAULT_CENTER_LNG=121.4737
NEXT_PUBLIC_DEFAULT_CENTER_LAT=31.2304
NEXT_PUBLIC_DEFAULT_ZOOM=9

# Tile source (replace with a stable/public source you can access in your environment)
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# Data mode: mock | file | db
DATA_PROVIDER_MODE=mock

# Mock/file paths
RESIDENTIAL_DATA_PATH=./src/data/mock/residential.geojson
DISTRICT_DATA_PATH=./src/data/mock/shanghai-districts.geojson
SCHOOL_DISTRICT_DATA_PATH=./src/data/mock/school-districts.json
NEARBY_RESOURCES_DATA_PATH=./src/data/mock/nearby-resources.json

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sh_housing
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sh_housing
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Search / cache (optional)
ENABLE_RESPONSE_CACHE=false
